# /etc/clinicmonitoring.env ga nusxa: sudo cp deploy/clinicmonitoring.env.example /etc/clinicmonitoring.env
# Keyin: sudo chmod 600 /etc/clinicmonitoring.env

# Mahalliy ish: DJANGO_DEBUG=true. DEBUG=false da SESSION_COOKIE_SECURE/CSRF_COOKIE_SECURE yoqiladi — faqat HTTPS.
# Standart dev SECRET_KEY bilan DEBUG=false = xizmat ishga tushmaydi (DJANGO_SECRET_KEY majburiy).
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=OZINGIZNING-uzun-va-tasodifiy-maxfiy-kalit
DJANGO_ALLOWED_HOSTS=clinicmonitoringapi.ziyrak.org,127.0.0.1,localhost,167.71.53.238
CORS_ALLOWED_ORIGINS=https://clinicmonitoring.ziyrak.org,https://clinicmonitoringapi.ziyrak.org,http://127.0.0.1:5173,http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://clinicmonitoring.ziyrak.org,https://clinicmonitoringapi.ziyrak.org

BIND_HOST=127.0.0.1
PORT=8010
# Tasodifiy vitallar simulyatsiyasi (faqat mahalliy DEBUG=true da yoqiladi)
SKIP_SIMULATION=1
# Prezentatsiya: HL7siz namuna vitallar (DEBUG=false ham ishlaydi; klinikada O‘CHIQ)
# DEMO_LIVE_VITALS=1

# Frontend build (remote-update.sh ham ishlatadi)
VITE_API_ORIGIN=https://clinicmonitoringapi.ziyrak.org

# HL7 (Mindray MLLP, default 6006)
# HL7_LISTENER_ENABLED=1
# HL7_LISTEN_PORT=6006
# HL7_MAX_BUFFER_BYTES=2097152
# DEVICE_ONLINE_SILENCE_SEC=120
